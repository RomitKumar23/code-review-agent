# Copy this to .env and fill in your values

# ── GitHub ─────────────────────────────────────────────
# Create at: GitHub → repo Settings → Webhooks
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Personal Access Token with repo + pull_requests scope
# Create at: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_APP_TOKEN=ghp_your_token_here

# ── LLM Providers ──────────────────────────────────────
# Fill in only the provider(s) you want to use

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Ollama runs locally via Docker — no key needed
OLLAMA_BASE_URL=http://ollama:11434

# ── Active Provider ─────────────────────────────────────
# Change this to switch providers — NO code changes required
# Options: openai | anthropic | ollama
ACTIVE_LLM_PROVIDER=openai
ACTIVE_LLM_MODEL=gpt-4o

# ── Infrastructure ──────────────────────────────────────
# These match the docker-compose.yml defaults — only change if needed
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/codereviewer
REDIS_URL=redis://redis:6379/0
